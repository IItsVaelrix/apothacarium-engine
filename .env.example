# ──────────────────────────────────────────────────────────────────────────
# Apothacarium Engine — example environment.
# Generate a real .env with:  npm run init:secrets
# ──────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=false
API_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000

# Session & CSRF
SESSION_SECRET=<random-32+>
ENABLE_REDIS_SESSIONS=false
REDIS_URL=redis://localhost:6379

# Databases (local SQLite by default; set TURSO_* to use libsql cloud)
USER_DB_PATH=./data/apothacarium_user.sqlite
COLLAB_DB_PATH=./data/apothacarium_collab.sqlite
ABYSS_DB_PATH=./data/apothacarium_abyss.sqlite
SCHOLOMANCE_DICT_PATH=./data/scholomance_dict.sqlite
SCHOLOMANCE_CORPUS_PATH=./data/scholomance_corpus.sqlite
CORPUS_DB_PATH=./data/scholomance_corpus.sqlite
DB_BUSY_TIMEOUT_MS=5000

# TURSO (leave empty for local)
TURSO_COLLAB_DB_URL=
TURSO_COLLAB_DB_TOKEN=
TURSO_USER_DB_URL=
TURSO_USER_DB_TOKEN=
TURSO_ABYSS_DB_URL=
TURSO_ABYSS_DB_TOKEN=

# Collab API
ENABLE_COLLAB_API=true
COLLAB_REMOTE_ACCESS=false
COLLAB_ALLOWED_ORIGINS=
COLLAB_AGENT_RATE_LIMIT_MAX=120
COLLAB_AGENT_RATE_LIMIT_WINDOW=1 minute
COLLAB_KEY_EXPIRY_DAYS=0

# MCP agent auto-registration (optional)
AGENT_ID=
AGENT_NAME=
AGENT_ROLE=
AGENT_CAPS=

# Apothacarium app metadata
APP_NAME=Apothacarium
APP_BASE_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_SERVER_URL=http://localhost:3000

# Frontend / Vite (kept for compatibility with carried-over services)
VITE_API_BASE_URL=http://localhost:3000
VITE_PUBLIC_APP_URL=http://localhost:3000

# Audio storage
AUDIO_STORAGE_PATH=./public/audio
AUDIO_ADMIN_TOKEN=<random-48+>

# Feature flags
SERVE_FRONTEND=false
ENABLE_DEV_AUTH=false
ENABLE_RHYME_ASTROLOGY=false
ENABLE_SYNTAX_RHYME_LAYER=false
ENABLE_TURBOQUANT=false
ENABLE_PANEL_ANALYSIS_CACHE=true
ENABLE_PANEL_ANALYSIS_REDIS_CACHE=false

# Email (default: console output, no real send)
MAIL_PROVIDER=console
EMAIL_FROM=noreply@apothacarium.local
EMAIL_FROM_NAME=Apothacarium

# SendGrid / Resend (leave empty unless configured)
SENDGRID_API_KEY=
RESEND_API_KEY=

# SMTP
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false

# Cloudflare R2 (optional, for audio storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
CLOUDFLARE_ACCOUNT_ID=

# HTTPS (production only)
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Render sync (optional)
RENDER_API_KEY=
RENDER_SERVICE_ID=

# Panel analysis cache
PANEL_ANALYSIS_CACHE_TTL_MS=300000
PANEL_ANALYSIS_CACHE_MAX_SIZE=1000
