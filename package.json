{
  "name": "apothacarium-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Apothacarium poster generation engine. Sister codebase to Scholomance — extracts PixelBrain visual logic and carries the collab/MCP/server backbone.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --env-file=.env codex/server/index.js",
    "start:server": "node --env-file=.env codex/server/index.js",

    "init:secrets": "node scripts/init-secrets.js",
    "init:secrets:force": "node scripts/init-secrets.js --force",

    "mcp:collab": "node --env-file=.env codex/server/collab/mcp-bridge.js",
    "mcp:probe": "node scripts/debug-mcp-bridge.js",
    "mcp:probe:env": "node --env-file=.env scripts/debug-mcp-bridge.js",
    "mcp:call": "node scripts/call-mcp-tool.js",
    "mcp:functional-audit": "node scripts/mcp-functional-audit.js",

    "collab:client": "node scripts/collab-client.js",
    "collab:admin": "node scripts/collab-admin.js",
    "collab:daemon": "node scripts/collab-daemon.js",
    "collab:connect": "node scripts/connect-collab.js",
    "collab:verify": "node scripts/verify-collab-v1.1.js",

    "cleri": "node scripts/cleri-raid.js",
    "cleri:probe": "node scripts/cleri-probe.js",

    "immune:scan": "node scripts/immunity-pre-commit.js --staged",
    "immune:scan:all": "node scripts/immunity-pre-commit.js --all",
    "immune:scan:json": "node scripts/immunity-pre-commit.js --staged --json",

    "diagnostic:scan": "node codex/core/diagnostic/run-diagnostic.cli.js",
    "diagnostic:scan:ci": "node codex/core/diagnostic/run-diagnostic.cli.js --trigger ci",
    "diagnose:db": "node scripts/diagnose-db-health.js",

    "sani:scan": "node scripts/pb-sani/run.js",
    "sani:scan:json": "node scripts/pb-sani/run.js --json",
    "sani:delete": "node scripts/pb-sani/run.js --status DELETE",
    "sani:archive": "node scripts/pb-sani/run.js --status ARCHIVE",
    "sani:review": "node scripts/pb-sani/run.js --status REVIEW",

    "bible:synthesis": "node scripts/bible-synthesis.js",
    "memory:infuse": "node scripts/memory-cell-infusion.js",
    "polish": "node scripts/production-polish.js full",
    "polish:quick": "node scripts/production-polish.js quick",
    "polish:ci": "node scripts/production-polish.js full --ci",

    "verify:backend-contract": "node scripts/verify-backend-contract.js",
    "verify:rhyme-astrology:phase0": "node scripts/verify-rhyme-astrology-phase0.js",
    "build:rhyme-astrology:index": "node scripts/buildRhymeAstrologyIndex.js",

    "audit:bytecode-vectors": "node scripts/audit_bytecode_vectors.js",
    "audit:dead-code": "node scripts/dead-code-detector.mjs",
    "audit:cell-wall": "node scripts/cell-wall-audit.js",

    "heartbeat": "node scripts/heartbeat-pulse.mjs",
    "heartbeat:permanent": "node scripts/permanent-heartbeat.js",

    "db:setup": "node scripts/setup_database.cjs",
    "ritual:init": "node scripts/ritual-init.js",

    "security:qa": "node scripts/security/security-qa.js",
    "security:audit": "node scripts/security/dependency-audit.js",

    "generate": "node adapters/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:integration:full": "node tests/integration/full-pipeline.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@babel/parser": "^7.29.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "cmudict": "^1.0.2",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.2.1",
    "mammoth": "^1.11.0",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
