{
  "name": "apothacarium-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Apothacarium poster generation engine. Sister codebase to Scholomance — extracts PixelBrain visual logic and carries the collab/MCP/server backbone.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --env-file=.env codex/server/index.js",
    "start:server": "node --env-file=.env codex/server/index.js",
    "mcp:collab": "node --env-file=.env codex/server/collab/mcp-bridge.js",
    "mcp:probe": "node codex/server/collab/mcp-probe.js",
    "generate": "node adapters/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@babel/parser": "^7.29.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "cmudict": "^1.0.2",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.2.1",
    "mammoth": "^1.11.0",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
