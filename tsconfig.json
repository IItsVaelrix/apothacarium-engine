{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "core/**/*.js",
    "core/**/*.ts",
    "adapters/**/*.js",
    "adapters/**/*.ts",
    "codex/**/*.js",
    "codex/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "output",
    "tests"
  ]
}
